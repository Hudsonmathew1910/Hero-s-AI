# Auto-detect text files and normalize line endings
* text=auto

# Force LF for Python, JS, CSS, HTML, and config files
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files — never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
