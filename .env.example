# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
NEON_DB_NAME=your_db_name
NEON_DB_USER=your_db_user
NEON_DB_PASSWORD=your_db_password
NEON_DB_HOST=your_neon_host.neon.tech
NEON_DB_PORT=5432

# ── Django Core ────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Encryption Key (for stored API keys) ──────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ── Google OAuth (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SITE_URL=https://yourdomain.com
